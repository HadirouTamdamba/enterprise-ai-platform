# ==============================================================================
# Enterprise AI Platform — environment template
# Copy to .env and fill in. Never commit .env.
# ==============================================================================

# --- Application ---
ENVIRONMENT=development
APP_NAME=enterprise-ai-platform
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Security ---
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# --- Initial admin (seeded on first start) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=eap
POSTGRES_PASSWORD=eap-secret
POSTGRES_DB=eap

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Qdrant (vector database) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=eap

# --- LLM providers (fill at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
VERTEX_PROJECT_ID=
OLLAMA_BASE_URL=http://ollama:11434

# --- Model defaults (never hardcode in code) ---
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-5
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4o
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- RAG defaults (overridable per knowledge base) ---
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.35
RAG_RERANK_ENABLED=true

# --- Rate limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=120
LLM_RATE_LIMIT_TOKENS_PER_MINUTE=200000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_METRICS_ENABLED=true

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
